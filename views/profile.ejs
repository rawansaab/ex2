<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile My</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Rammetto+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/profile.css" />
</head>
<body>
  <div class="main-container">
    <h1 class="main-title">Profile My</h1>
    <div class="content-block info-section">
      <div class="text-column">
        <p><%= animal.description %></p>
        
        <div class="info-row">
          <div class="info-label">
            <p>Stats / Traits</p>
          </div>
          <div class="info-value">
            <p>
              <% for (let i = 0; i < traits.length; i++) { %>
                <strong><%= traits[i].trait_name %>:</strong> <%= traits[i].trait_value %><br>
              <% } %>
            </p>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</body>
</html>