<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Rammetto+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/profile.css" />
</head>
<body>
  <div class="main-container">
    
    <header id="banner" style="background-image: url('/<%= id %>/banner.png');">
      <div class="banner-inner">
        <div class="profile-img-wrapper">
          <img class="profile-img" src="/<%= id %>/profile.png" alt="Profile Picture">
        </div>
      </div>
    </header>

    <h1 class="main-title">My Profile</h1>
    <div class="content-block info-section">
      <div class="text-column">
        <p><%= animal.description %></p>
        
        <div class="info-row">
          <div class="info-label">
            <p>Stats / Traits</p>
          </div>
          <div class="info-value">
            <p>
              <% for (let i = 0; i < traits.length; i++) { %>
                <strong><%= traits[i].trait_name %>:</strong> <%= traits[i].trait_value %><br>
              <% } %>
            </p>
          </div>
        </div>
        
      </div>

      <div class="image-column">
        <img src="/<%= id %>/image1.png" alt="animal main picture">
      </div>
      
    </div>

    <div class="content-block endorsements-section">
      <div class="text-column">
        <h2>Endorsements</h2>
        <% for (let i = 0; i < reviews.length; i++) { %>
          <div class="endorsement-card">
            <p>"<%= reviews[i].review_text %>"</p> 
            <hr>
            <span>- <%= reviews[i].reviewer_name %></span> 
          </div>
        <% } %>
      </div>
    </div>

    <div class="friends-section">
      <h2>Friends</h2>
      <div class="friends-grid">
        <img src="/<%= id %>.png" alt="friend 1">
        <img src="/<%= id %>.png" alt="friend 2">
        <img src="/<%= id %>.png" alt="friend 3">
        <img src="/<%= id %>.png" alt="friend 4">
      </div>
    </div>

    <footer>
      Zefat Academic College
    </footer>

  </div> 
</body>
</html>